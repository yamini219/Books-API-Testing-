        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Base URL setup\r",
              "var url = \"https://simple-books-api.glitch.me\";\r",
              "pm.collectionVariables.set(\"baseurl\",url);\r",
              "\r",
              "// Generate random data\r",
              "var randomdata = Math.random().toString(36).substring(2);\r",
              "var clientName = randomdata\r",
              "var clientEmail = randomdata + \"@test.com\";\r",
              "\r",
              "// Store variables\r",
              "pm.collectionVariables.set(\"randomclientName\",clientName);\r",
              "pm.collectionVariables.set(\"randomclientEmail\",clientEmail);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
