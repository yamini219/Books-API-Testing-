    {
      "name": "List of All Books",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Validate status code\r",
              "pm.test(\"To verify the status code is 200\",()=>{pm.response.to.have.status(200)});\r",
              "\r",
              "//validate status message\r",
              "pm.test(\"To verify the status message is OK\",()=>{pm.response.to.have.status(\"OK\")});\r",
              "\r",
              "//validate response time\r",
              "pm.test(\"To verify Response time should be acceptable\",()=>{pm.expect(pm.response.responseTime).to.be.below(1000)});\r",
              "\r",
              "//Parse json and validate response should not be empty\r",
              "var booksdata = pm.response.json();\r",
              "pm.test(\"Books list should not empty\",()=>{pm.expect(booksdata.length).to.be.above(0)});\r",
              "\r",
              "//Schema validation\r",
              "var schema = {\r",
              "  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r",
              "  \"title\": \"Generated schema for Root\",\r",
              "  \"type\": \"array\",\r",
              "  \"items\": {\r",
              "    \"type\": \"object\",\r",
              "    \"properties\": {\r",
              "      \"id\": {\r",
              "        \"type\": \"number\"\r",
              "      },\r",
              "      \"name\": {\r",
              "        \"type\": \"string\"\r",
              "      },\r",
              "      \"type\": {\r",
              "        \"type\": \"string\"\r",
              "      },\r",
              "      \"available\": {\r",
              "        \"type\": \"boolean\"\r",
              "      }\r",
              "    },\r",
              "    \"required\": [\r",
              "      \"id\",\r",
              "      \"name\",\r",
              "      \"type\",\r",
              "      \"available\"\r",
              "    ]\r",
              "  }\r",
              "}\r",
              "pm.test(\"To verify the schema is valid\", () => {\r",
              "    pm.expect(tv4.validate(booksdata,schema)).to.be.true\r",
              "});\r",
              "\r",
              "//Storing the book id in variable\r",
              "pm.collectionVariables.set(\"Bookid\",booksdata[0].id);\r",
              "pm.collectionVariables.set(\"Bookname\",booksdata[0].name);\r",
              "pm.collectionVariables.set(\"Booktype\",booksdata[0].type);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
