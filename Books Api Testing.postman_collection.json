      "name": "Auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Validate status code\r",
              "pm.test(\"To verify the status code is 201\",()=>{pm.response.to.have.status(201)});\r",
              "\r",
              "//Validate status message\r",
              "pm.test(\"To verify the status message is created\",()=>{pm.response.to.have.status(\"Created\")});\r",
              "\r",
              "//Parse response\r",
              "var responsedata = pm.response.json();\r",
              "\r",
              "//Store token\r",
              "pm.environment.set(\"token\",responsedata.accessToken);\r",
              "\r",
              "//Validated token\r",
              "pm.test(\"Token generated\",()=>{pm.expect(responsedata.accessToken).to.not.be.empty});\r",
              "\r",
              ""
